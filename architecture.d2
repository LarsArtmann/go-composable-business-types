# CBT (Composable Business Types) Architecture
# Go 1.26 | Selective Imports
# 
# Direction: right

# ============================================
# STYLES
# ============================================

classes: {
  core: {
    style: {
      fill: "#e3f2fd"
      stroke: "#1976d2"
      stroke-width: 2
      border-radius: 8
      shadow: true
    }
  }
  generic: {
    style: {
      fill: "#fff8e1"
      stroke: "#f57c00"
      border-radius: 8
      double-border: true
    }
  }
  enum: {
    style: {
      fill: "#f3e5f5"
      stroke: "#7b1fa2"
      border-radius: 8
    }
  }
  value: {
    style: {
      fill: "#e8f5e9"
      stroke: "#388e3c"
      border-radius: 8
    }
  }
  external: {
    style: {
      fill: "#fff3e0"
      stroke: "#f57c00"
      stroke-dash: 3
      border-radius: 8
    }
  }
}

# ============================================
# PACKAGES (Selective Imports)
# ============================================

packages: {
  pk_id: {class: core; label: "**id**\nID[B, V]"}
  pk_nanoid: {class: core; label: "**nanoid**\nNanoId"}
  pk_bounded: {class: value; label: "**bounded**\nBoundedString"}
  pk_types: {class: value; label: "**types**\nEmail, URL\nCents\nPercentage\nTimestamp\nDuration"}
  pk_enums: {class: enum; label: "**enums**\nActorKind\nPriority\nStatus\nTrigger"}
  pk_locale: {class: value; label: "**locale**\nLocale"}
  pk_temporal: {class: core; label: "**temporal**\nBitemporal"}
  pk_actor: {class: core; label: "**actor**\nActorChain[T]\nActorEntry[T]"}
  pk_money: {class: value; label: "**money**\nMoney"}
  pk_datapoint: {class: core; label: "**datapoint**\nDataPoint[T]\nContext\nReference[T]\nCause[T]"}
}

# Package dependencies
pk_datapoint -> pk_nanoid: uses
pk_datapoint -> pk_actor: uses
pk_datapoint -> pk_temporal: uses
pk_datapoint -> pk_enums: uses
pk_datapoint -> pk_types: uses
pk_actor -> pk_enums: uses
pk_actor -> pk_id: uses
pk_temporal -> pk_types: uses
pk_money -> pk_locale: uses

# ============================================
# CORE TYPES
# ============================================

datapoint: {
  class: core
  label: |md
    **DataPoint[T]**
    Self-contained data unit with audit trail
    
    • id: NanoId
    • payload: T
    • actor: ActorEntry
    • temporal: Bitemporal
    • trigger: Trigger
    • context: Context
    • references: []Reference
    • causes: []Cause
  |
}

actor_entry: {
  class: core
  label: |md
    **ActorEntry[T]**
    Actor in a chain
    
    • Kind: ActorKind
    • Id: ID[T]
    • Name: string
  |
}

actor_chain: {
  class: core
  label: |md
    **ActorChain[T]**
    Ordered actor history
    
    []ActorEntry[T]
    • Origin() - first actor
    • Current() - last actor
  |
}

bitemporal: {
  class: core
  label: |md
    **Bitemporal**
    Valid time + Transaction time
    
    • validFrom: Timestamp
    • validUntil: Timestamp
    • recorded: Timestamp
    • correction: bool
  |
}

context: {
  class: core
  label: |md
    **Context**
    Execution metadata
    
    • environment: string
    • session: string
    • request: string
    • source: string
  |
}

reference: {
  class: core
  label: |md
    **Reference[T]**
    Entity reference
    
    • id: T
    • relation: string
    • version: int
  |
}

cause: {
  class: core
  label: |md
    **Cause[T]**
    Causal relationship
    
    • id: NanoId
    • kind: string
    • effect: string
  |
}

# ============================================
# IDENTIFIERS
# ============================================

nanoid: {
  class: core
  label: |md
    **NanoId**
    URL-safe unique ID
    
    • Length: 8-256 chars
    • Default: 21 chars (126 bits)
    • FIPS-140 compatible
  |
}

id: {
  class: generic
  label: |md
    **ID[B, V]**
    Branded phantom type ID
    
    Prevents mixing entity IDs at compile time
    
    ```go
    type UserBrand struct{}
    type UserID = ID[UserBrand, string]
    ```
  |
}

# ============================================
# VALUE TYPES
# ============================================

email: {class: value; label: "**Email**\nRFC 5322 validated"}
url: {class: value; label: "**URL**\nParsed URL"}
percentage: {class: value; label: "**Percentage**\n0-100 (uint8)"}
cents: {class: value; label: "**Cents**\nMonetary (int64)"}
money: {class: value; label: "**Money**\nISO 4217 currency"}
bounded_string: {class: value; label: "**BoundedString**\nLength-constrained"}
locale: {class: value; label: "**Locale**\nBCP 47 language tag"}
timestamp: {class: value; label: "**Timestamp**\ntime.Time wrapper"}
duration: {class: value; label: "**Duration**\ntime.Duration wrapper"}

# ============================================
# ENUMS
# ============================================

actor_kind: {class: enum; label: "**ActorKind**\nUser\nBot\nSystem\nService"}
priority: {class: enum; label: "**Priority**\nLow\nMedium\nHigh\nCritical"}
status: {class: enum; label: "**Status**\nDraft\nActive\nPaused\nArchived\nDeleted"}
trigger: {class: enum; label: "**Trigger**\nManual\nScheduled\nWebhook\nImport\nMigration\nSystem\nCorrection"}

# ============================================
# EXTERNAL DEPENDENCIES
# ============================================

ext_currency: {
  class: external
  label: |md
    **bojanz/currency**
    ISO 4217 handling
    
    currency.Amount
    currency.Formatter
  |
}

ext_nanoid: {
  class: external
  label: |md
    **sixafter/nanoid**
    FIPS-140 compatible
    High-performance
  |
}

ext_language: {
  class: external
  label: |md
    **x/text/language**
    BCP 47 language tags
    
    language.Tag
  |
}

# ============================================
# RELATIONSHIPS
# ============================================

# DataPoint composition
datapoint -> nanoid: id
datapoint -> actor_entry: actor
datapoint -> bitemporal: temporal
datapoint -> trigger: trigger
datapoint -> context: context
datapoint -> reference: "references[]"
datapoint -> cause: "causes[]"

# Actor chain
actor_chain -> actor_entry: contains
actor_entry -> actor_kind: kind
actor_entry -> id: id

# Bitemporal
bitemporal -> timestamp: validFrom
bitemporal -> timestamp: validUntil
bitemporal -> timestamp: recorded

# Money
money -> ext_currency: wraps
money -> locale: locale
cents -> money: converts to

# Locale
locale -> ext_language: wraps

# NanoId
nanoid -> ext_nanoid: uses

# ============================================
# GROUPS
# ============================================

Packages: {packages}

Core: {datapoint; actor_chain; actor_entry; bitemporal; context; reference; cause}

Identifiers: {nanoid; id}

Values: {email; url; percentage; cents; money; bounded_string; locale; timestamp; duration}

Enums: {actor_kind; priority; status; trigger}

External: {ext_currency; ext_nanoid; ext_language}
